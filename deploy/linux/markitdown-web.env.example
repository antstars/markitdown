MARKITDOWN_WEB_PASSWORD=change-me
MARKITDOWN_WEB_SECRET_KEY=replace-with-a-long-random-secret
MARKITDOWN_WEB_TEMP_DIR=/var/lib/markitdown-web
MARKITDOWN_WEB_MAX_FILE_MB=50
MARKITDOWN_WEB_MAX_BATCH=20
MARKITDOWN_WEB_TTL_MINUTES=60
MARKITDOWN_WEB_MAX_WORKERS=2
MARKITDOWN_WEB_URL_TIMEOUT_SECONDS=20
MARKITDOWN_ENABLE_PLUGINS=false
